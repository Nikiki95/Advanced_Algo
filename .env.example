# === Betting Algorithm Suite V6 ===
# Copy to secrets/.env

# TheOddsAPI
THEODDS_API_KEY=

APISPORTS_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMANDS_ENABLED=true
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_INTERVAL=3
TELEGRAM_MAX_RUNTIME_MINUTES=120

# Execution mode: live | shadow
EXECUTION_MODE=live

# Optional feature flags
PLAYER_PROPS_ENABLED=true

# Optional pipeline/runtime settings
PIPELINE_TIMEZONE=UTC
